# TripTime production runtime env
TTS_PROVIDER=naver_playwright
TTS_TIMEZONE=Asia/Seoul
TTS_HOST=0.0.0.0
TTS_PORT=8500
TTS_RELOAD=false
TTS_HEADLESS=true

# Throughput tuning
TTS_CACHE_TTL_SECONDS=600
TTS_STEP_MINUTES=10
TTS_LOOKBACK_HOURS=3
TTS_MAX_QUERIES=120
TTS_RECOMMEND_MIN_SAMPLES=12
TTS_NAVER_SESSION_POOL_SIZE=4
TTS_RECOMMEND_WORKERS=4

# External integrations
TTS_NAVER_MAP_CLIENT_ID=
TTS_CORS_ALLOW_ORIGINS=https://triptime.enmsoftware.com

# Set by deploy.sh from the image/tag at runtime.
