# TripTime non-main(development) runtime env
# Dev also uses real provider by default; use mock only for local/e2e test runs.
TTS_PROVIDER=naver_playwright
TTS_TIMEZONE=Asia/Seoul
TTS_HOST=0.0.0.0
TTS_PORT=8500
TTS_RELOAD=false
TTS_HEADLESS=true

# Throughput tuning (dev can be lower than prod)
TTS_CACHE_TTL_SECONDS=300
TTS_STEP_MINUTES=10
TTS_LOOKBACK_HOURS=3
TTS_MAX_QUERIES=80
TTS_RECOMMEND_MIN_SAMPLES=8
TTS_NAVER_SESSION_POOL_SIZE=2
TTS_RECOMMEND_WORKERS=2

# External integrations
TTS_NAVER_MAP_CLIENT_ID=
TTS_CORS_ALLOW_ORIGINS=https://dev.triptime.enmsoftware.com

# Set by deploy.sh from the image/tag at runtime.
